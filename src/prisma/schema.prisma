generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Better Auth Tables ─────────────────────────────────────────────────────

model User {
  id             String   @id
  name           String
  email          String   @unique
  emailVerified  Boolean  @default(false)
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  role           String   @default("user")
  coinsBalance   Int      @default(3)
  coinsPurchased Int      @default(0)
  agentPrompt    String?  @db.Text
  preferredModel String   @default("openai/gpt-4o-mini")

  sessions  Session[]
  accounts  Account[]
  threads   Thread[]
  purchases Purchase[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ─── Application Tables ─────────────────────────────────────────────────────

enum ThreadStatus {
  IDLE
  PROCESSING
  WAITING
}

enum SubThreadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Thread {
  id                   String       @id @default(cuid())
  title                String       @default("New Thread")
  userId               String
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages             Message[]
  files                File[]
  subThreads           SubThread[]
  status               ThreadStatus @default(IDLE)
  /// Last chat turn usage (OpenRouter), optional if provider omits usage
  lastPromptTokens     Int?
  lastCompletionTokens Int?
  lastTotalTokens      Int?
  /// Model context window for last request (from OpenRouter models API)
  contextLength        Int?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  isArchived           Boolean      @default(false)

  @@index([userId])
}

model SubAgent {
  id           String                @id @default(cuid())
  name         String                @unique
  instructions String                @db.Text
  model        String
  outputFormat String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  params       SubAgentParam[]
  outputParams SubAgentOutputParam[]
  subThreads   SubThread[]
}

model SubAgentParam {
  id          String   @id @default(cuid())
  subAgentId  String
  subAgent    SubAgent @relation(fields: [subAgentId], references: [id], onDelete: Cascade)
  name        String
  type        String
  description String   @db.Text
  required    Boolean  @default(true)

  @@index([subAgentId])
}

/// Describes expected shape of sub-agent output (hints in system prompt; not JSON Schema enforcement).
model SubAgentOutputParam {
  id          String   @id @default(cuid())
  subAgentId  String
  subAgent    SubAgent @relation(fields: [subAgentId], references: [id], onDelete: Cascade)
  name        String
  type        String
  description String   @db.Text

  @@index([subAgentId])
}

model SubThread {
  id               String             @id @default(cuid())
  threadId         String
  thread           Thread             @relation(fields: [threadId], references: [id], onDelete: Cascade)
  subAgentId       String
  subAgent         SubAgent           @relation(fields: [subAgentId], references: [id], onDelete: Cascade)
  anchorMessageId  String?
  anchorMessage    Message?           @relation("SubThreadAnchor", fields: [anchorMessageId], references: [id], onDelete: SetNull)
  input            Json
  output           String?            @db.Text
  status           SubThreadStatus    @default(PENDING)
  error            String?            @db.Text
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  contextLength    Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  messages         SubThreadMessage[]

  @@index([threadId])
  @@index([subAgentId])
  @@index([anchorMessageId])
}

model SubThreadMessage {
  id          String    @id @default(cuid())
  subThreadId String
  subThread   SubThread @relation(fields: [subThreadId], references: [id], onDelete: Cascade)
  role        String
  content     String    @db.Text
  createdAt   DateTime  @default(now())
  /// When set, a short notice was appended to the main thread for this reply.
  submittedAt DateTime?

  @@index([subThreadId])
}

model Message {
  id                 String      @id @default(cuid())
  threadId           String
  thread             Thread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role               String
  content            String      @db.Text
  model              String?
  files              File[]
  createdAt          DateTime    @default(now())
  anchoredSubThreads SubThread[] @relation("SubThreadAnchor")

  @@index([threadId])
}

model File {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  messageId String?
  message   Message? @relation(fields: [messageId], references: [id])
  name      String
  url       String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}

model Purchase {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  stripeId    String   @unique
  coinsAmount Int
  amountPaid  Int
  createdAt   DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model CoinPackage {
  id           String   @id @default(cuid())
  label        String
  coins        Int
  priceInCents Int
  isPopular    Boolean  @default(false)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
